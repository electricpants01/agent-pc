# ============================================
# Agent-PC Server Configuration (Tool Engine)
# ============================================
# Copy to .env and edit values.
# Open WebUI handles LLM — this server only
# executes tools on the host machine.
# ============================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# --- Workspace ---
# Root directory the agent is allowed to operate in
WORKSPACE_ROOT=/home/your-username

# --- Security ---
# Shared secret between Open WebUI and Agent-PC
AUTH_SECRET=agent-pc-local-secret-change-me

# --- SSH (for executing commands on the real host) ---
SSH_HOST=host.docker.internal
SSH_PORT=22
SSH_USER=your-username
SSH_KEY_PATH=/home/agentpc/.ssh/id_rsa
# Fall back to local execution if SSH fails
FALLBACK_TO_LOCAL=true

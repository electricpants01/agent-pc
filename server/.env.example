# ============================================
# Agent-PC Server Configuration (Tool Engine)
# ============================================
# Cópialo a .env y edita los valores.
# El LLM ahora lo maneja Open WebUI — este server
# solo ejecuta herramientas en la máquina host.
# ============================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# --- Workspace ---
# Directorio raíz donde el agente puede operar
WORKSPACE_ROOT=/home/tu-usuario

# --- Seguridad ---
# Clave compartida entre Open WebUI y Agent-PC
AUTH_SECRET=agent-pc-local-secret-change-me

# --- SSH (para ejecutar comandos en el host real) ---
SSH_HOST=host.docker.internal
SSH_PORT=22
SSH_USER=tu-usuario
SSH_KEY_PATH=/home/agentpc/.ssh/id_rsa
# Si SSH falla, ejecutar comandos dentro del contenedor
FALLBACK_TO_LOCAL=true

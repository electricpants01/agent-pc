# ============================================
# Agent-PC — Docker Compose Environment
# ============================================
# Copy to .env and edit values.
# $ cp .env.docker .env
# ============================================

# --- Ports (change if already in use) ---
OPENWEBUI_PORT=3000
AGENTPC_PORT=8765
OLLAMA_PORT=11434

# --- Open WebUI ---
# Secret key for signing Open WebUI sessions
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# --- Agent-PC Server ---
# Shared secret between Open WebUI and Agent-PC
AUTH_SECRET=agent-pc-local-secret-change-me

# Workspace root (directory the agent has access to)
WORKSPACE_ROOT=/home/your-username

# SSH for accessing host from container
SSH_HOST=host.docker.internal
SSH_PORT=22
SSH_USER=your-username
SSH_KEY_PATH=/home/agentpc/.ssh/id_rsa
FALLBACK_TO_LOCAL=true

# --- Tailscale (optional) ---
# Get an auth key at: https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
TS_HOSTNAME=agent-pc

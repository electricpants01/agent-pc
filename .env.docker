# ============================================
# Agent-PC — Docker Compose Environment
# ============================================
# Copia este archivo a .env y edita los valores.
# $ cp .env.docker .env
# ============================================

# --- Puertos (cambia si ya están en uso) ---
OPENWEBUI_PORT=3000
AGENTPC_PORT=8765
OLLAMA_PORT=11434

# --- Open WebUI ---
# Clave secreta para firmar sesiones de Open WebUI
WEBUI_SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# --- Agent-PC Server ---
# Clave compartida entre Open WebUI y Agent-PC
AUTH_SECRET=agent-pc-local-secret-change-me

# Workspace root (directorio al que el agente tiene acceso)
WORKSPACE_ROOT=/home/tu-usuario

# SSH para acceder al host desde el contenedor
SSH_HOST=host.docker.internal
SSH_PORT=22
SSH_USER=tu-usuario
SSH_KEY_PATH=/home/agentpc/.ssh/id_rsa
FALLBACK_TO_LOCAL=true

# --- Tailscale (opcional) ---
# Obtén una auth key en: https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
TS_HOSTNAME=agent-pc
